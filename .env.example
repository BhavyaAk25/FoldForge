# Server-only OpenAI credential. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Explicit opt-in. Leave false for deterministic offline contracts and no paid calls.
ENABLE_LIVE_OPENAI=false

# Paid evaluation only; do not set this in production. The user authorized at
# most $4.00, and FoldForge keeps a $0.30 safety reserve by enforcing $3.70.
LIVE_EVAL_BUDGET_USD=3.70

# Emergency kill switch. Any configured value other than exactly false blocks live calls.
LIVE_MODEL_KILL_SWITCH=false

# Required when live AI is enabled. Use at least 12 random characters.
DEMO_ACCESS_CODE=

# At least 32 random bytes. Used to sign short-lived access cookies.
ACCESS_COOKIE_SECRET=
