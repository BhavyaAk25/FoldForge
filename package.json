{
  "name": "foldforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run tests/property",
    "coverage": "vitest run --coverage",
    "fixture": "tsx scripts/generate-fixture.ts",
    "verify:artifact": "tsx scripts/verify-artifact.ts",
    "eval:offline": "tsx scripts/run-offline-evals.ts",
    "eval:compiler": "tsx scripts/run-compiler-evals.ts",
    "eval:repair": "tsx scripts/run-repair-evals.ts",
    "eval:e2e": "tsx scripts/run-e2e-evals.ts",
    "eval:ablation": "tsx scripts/run-ablation.ts",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run format:check && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "geist": "1.7.2",
    "next": "16.2.10",
    "openai": "6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fast-check": "4.9.0",
    "prettier": "^3.9.5",
    "tsx": "4.23.1",
    "typescript": "^5",
    "vitest": "4.1.10"
  }
}
