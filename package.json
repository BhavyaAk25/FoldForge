{
  "name": "foldforge",
  "version": "0.1.0",
  "packageManager": "pnpm@11.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run tests/property",
    "coverage": "vitest run --coverage",
    "fixture": "tsx scripts/generate-fixture.ts",
    "verify:artifact": "tsx scripts/verify-artifact.ts",
    "validate:consumers": "tsx scripts/validate-consumer-exports.ts",
    "eval:offline": "tsx scripts/run-offline-evals.ts",
    "eval:compiler": "tsx scripts/run-compiler-evals.ts",
    "eval:repair": "tsx scripts/run-repair-evals.ts",
    "eval:e2e": "tsx scripts/run-e2e-evals.ts",
    "eval:ablation": "tsx scripts/run-ablation.ts",
    "eval:live": "tsx scripts/run-live-readiness.ts",
    "eval:live:replay": "tsx scripts/run-live-response-replay.ts",
    "eval:continue-ledger": "tsx scripts/prepare-paid-eval-continuation.ts",
    "test:e2e": "playwright test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run format:check && pnpm run test && pnpm run validate:consumers && pnpm run build"
  },
  "dependencies": {
    "@react-three/fiber": "9.6.1",
    "earcut": "3.2.3",
    "geist": "1.7.2",
    "next": "16.2.10",
    "openai": "6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.182.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.61.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.182.0",
    "@vitest/coverage-v8": "4.1.10",
    "dxf-parser": "1.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fast-check": "4.9.0",
    "fold": "0.12.0",
    "gltf-validator": "2.0.0-dev.3.10",
    "prettier": "^3.9.5",
    "tsx": "4.23.1",
    "typescript": "^5",
    "vitest": "4.1.10"
  }
}
